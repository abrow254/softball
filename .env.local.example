# ---- Supabase ----
# Project Settings → API. The anon key is safe to expose to the browser; RLS is
# the real gate. There is NO service-role key in app code — migrations/seed run
# via the Supabase SQL editor or CLI, not from the running app.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ---- Anthropic (photo intake — SERVER ONLY, never NEXT_PUBLIC_) ----
ANTHROPIC_API_KEY=sk-ant-...
# Optional override; defaults to claude-opus-4-8 (best on handwriting).
ANTHROPIC_MODEL=claude-opus-4-8
